// main tsconfig.json picks it up via its existing `js/**/*.js` include.
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "checkJs": true,
    "noImplicitAny": false
  },
  "include": ["js/app.js", "js/types.d.ts"],
  "exclude": ["js/search-worker.js"]
}
