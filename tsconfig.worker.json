{
  "//": "Web Worker 전용 tsconfig — DOM Window 글로벌 대신 WebWorker 라이브 사용. 메인 tsconfig.json은 search-worker.js를 exclude로 분리해 처리한다.",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "lib": ["WebWorker", "ES2022"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "js/search-worker.js"
  ]
}
